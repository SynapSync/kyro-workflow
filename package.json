{
  "name": "kyro-workflow",
  "version": "3.1.1",
  "description": "Complete sprint workflow system — 2 agents, 3 commands, 10 guardian events, adaptive learning, and formal debt tracking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "postbuild": "cp src/db/schema.sql dist/db/schema.sql",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "db:init": "node dist/db/index.js"
  },
  "keywords": [
    "claude-code",
    "workflow",
    "sprint",
    "planning",
    "execution",
    "debt-tracking",
    "roadmap",
    "iterative",
    "adaptive",
    "hooks",
    "agents",
    "subagents",
    "self-correction",
    "worktrees",
    "context-persistence"
  ],
  "author": {
    "name": "SynapSync",
    "url": "https://github.com/SynapSync"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SynapSync/kyro-workflow"
  },
  "homepage": "https://synapsync.dev/cognitives/kyro-workflow",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.2.2",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist",
    "commands",
    "agents",
    "skills",
    "docs",
    "rules",
    "contexts",
    "templates",
    "config.json",
    ".claude-plugin",
    "settings.example.json",
    "README.md"
  ]
}
